CORUN_SECRET_KEY=change-me
CORUN_DEBUG=True
CORUN_ALLOWED_HOSTS=localhost,127.0.0.1

CORUN_DB_NAME=corun
CORUN_DB_USER=corun
CORUN_DB_PASSWORD=corun
CORUN_DB_HOST=localhost
CORUN_DB_PORT=5432

# Subpath deployment (set for production behind Apache)
# CORUN_FORCE_SCRIPT_NAME=/doc
# CORUN_STATIC_URL=/doc/static/

# AI generation
# ANTHROPIC_API_KEY=sk-ant-...

# AI CLI paths (override defaults; leave unset to use built-in search list)
# CORUN_CLAUDE_PATH=/home/you/.local/bin/claude
# CORUN_GEMINI_PATH=/usr/local/bin/gemini

# Worker subprocess environment (defaults to current user's HOME and system PATH)
# CORUN_WORKER_HOME=/home/you
# CORUN_WORKER_PATH=/home/you/.local/bin:/usr/local/bin:/usr/bin:/bin

# PR cache (defaults to /var/www/corun-ai/data/epic_prs_cache.json)
# CORUN_PRS_CACHE_PATH=/path/to/epic_prs_cache.json
